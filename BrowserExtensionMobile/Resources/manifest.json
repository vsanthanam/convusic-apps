{
    "manifest_version": 3,
    "default_locale": "en",

    "name": "__MSG_extension_name__",
    "description": "__MSG_extension_description__",
    "version": "2.0",

    "icons": {
        "48": "images/icon-48.png",
        "96": "images/icon-96.png",
        "128": "images/icon-128.png",
        "256": "images/icon-256.png",
        "512": "images/icon-512.png"
    },

    "background": {
        "scripts": [ "background.js" ],
        "type": "module",
        "persistent": false
    },

    "content_scripts": [{
        "js": [ "content.js" ],
        "matches": [
            "*://music.apple.com/*",
            "*://open.spotify.com/*",
            "*://music.youtube.com/*",
            "*://*.tidal.com/*",
            "*://*.pandora.com/*",
            "*://music.amazon.com/*",
            "*://*.deezer.com/*"
        ]
    }],

    "action": {
        "default_popup": "popup.html",
        "default_icon": "images/toolbar-icon.svg"
    },

    "web_accessible_resources": [{
        "resources": [ "banner.css" ],
        "matches": [
            "*://music.apple.com/*",
            "*://open.spotify.com/*",
            "*://music.youtube.com/*",
            "*://*.tidal.com/*",
            "*://*.pandora.com/*",
            "*://music.amazon.com/*",
            "*://*.deezer.com/*"
        ]
    }],

    "host_permissions": [
        "*://music.apple.com/*",
        "*://open.spotify.com/*",
        "*://music.youtube.com/*",
        "*://*.tidal.com/*",
        "*://*.pandora.com/*",
        "*://music.amazon.com/*",
        "*://*.deezer.com/*"
    ],

    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+Shift+C",
                "mac": "Command+Shift+C"
            }
        }
    },

    "permissions": [ "nativeMessaging", "activeTab" ]
}
